		};
		top_vga_0: top_vga@c0000000 {
			xlnx,rable = <0>;
			compatible = "xlnx,top-vga-1.0";
			status = "okay";
			xlnx,ip-name = "top_vga";
			xlnx,edk-iptype = "PERIPHERAL";
