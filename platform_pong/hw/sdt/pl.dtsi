/ {
	clock: clocks {
		#address-cells = <1>;
		#size-cells = <0>;
		clk_cpu_0: clk_cpu@0 {
			compatible = "fixed-clock";
			reg = <0>;
			clock-frequency = <100000000>;
			clock-output-names = "clk_cpu";
			#clock-cells = <0>;
		};
		clk_bus_0: clk_bus_0@1 {
			compatible = "fixed-clock";
			reg = <1>;
			clock-frequency = <100000000>;
			clock-output-names = "clk_bus_0";
			#clock-cells = <0>;
		};
	};
	amba_pl: amba_pl {
		ranges;
		compatible = "simple-bus";
		#address-cells = <1>;
		#size-cells = <1>;
		cpus_microblaze_riscv_0: cpus_microblaze_riscv@0 {
			#cpu-mask-cells = <1>;
			compatible = "cpus,cluster";
			#address-cells = <1>;
			#size-cells = <0>;
			microblaze_riscv_0: cpu@0 {
				model = "microblaze_riscv,1.0";
				xlnx,d-axi = <1>;
				xlnx,pmp-entries = <0>;
				xlnx,interrupt-mon = <0>;
				xlnx,iaddr-size = <32>;
				xlnx,number-of-wr-addr-brk = <0>;
				xlnx,temporal-depth = <0>;
				xlnx,rable = <0>;
				xlnx,use-interrupt = <0>;
				xlnx,optimization = <0>;
				xlnx,ip-axi-mon = <0>;
				d-cache-highaddr = <0x3fffffff>;
				xlnx,ip-name = "microblaze_riscv";
				xlnx,dcache-force-tag-lutram = <0>;
				xlnx,pc-width = <32>;
				xlnx,interrupt-is-edge = <0>;
				reg = <0x0>;
				xlnx,async-interrupt = <1>;
				xlnx,use-mmu = <0>;
				xlnx,icache-victims = <0>;
				xlnx,use-bitman-a = <0>;
				xlnx,d-lmb-mon = <0>;
				xlnx,d-lmb-protocol = <0>;
				xlnx,use-bitman-b = <0>;
				xlnx,use-bitman-c = <0>;
				xlnx,dc-axi-mon = <0>;
				xlnx,debug-trace-async-reset = <0>;
				xlnx,trace = <0>;
				xlnx,part = "xc7a100tcsg324-1";
				xlnx,use-config-reset = <0>;
				xlnx,i-lmb-mon = <0>;
				xlnx,dcache-byte-size = <8192>;
				xlnx,ill-instr-exception = <2>;
				compatible = "xlnx,microblaze-riscv-1.0" , "xlnx,microblaze_riscv";
				xlnx,data-size = <32>;
				xlnx,fault-tolerant = <0>;
				xlnx,use-sleep = <0>;
				xlnx,debug-trace-size = <0>;
				xlnx,pmp-granularity = <2>;
				xlnx,mmu-privileged-instr = <0>;
				d-cache-line-size = <16>;
				xlnx,d-lmb = <1>;
				xlnx,enable-discrete-ports = <0>;
				clock-frequency = <100000000>;
				xlnx,debug-interface = <0>;
				xlnx,use-ext-brk = <0>;
				xlnx,daddr-size = <32>;
				xlnx,debug-enabled = <1>;
				xlnx,num-sync-ff-dbg-trace-clk = <2>;
				xlnx,i-lmb-protocol = <0>;
				xlnx,fsl-exception = <0>;
				xlnx,use-extended-fsl-instr = <0>;
				xlnx,dp-axi-mon = <0>;
				xlnx,impid = <0x00000000 0x00000001>;
				xlnx,branch-target-cache-size = <0>;
				xlnx,dcache-use-writeback = <0>;
				xlnx,use-bitman-s = <0>;
				bus-handle = <&amba_pl>;
				xlnx,icache-line-len = <4>;
				xlnx,base-vectors = <0x00000000 0x00000000>;
				xlnx,ecc-use-ce-exception = <0>;
				xlnx,use-dcache = <0>;
				xlnx,use-barrel = <1>;
				xlnx,edk-special = "microblaze_riscv";
				xlnx,use-muldiv = <0>;
				xlnx,addr-size = <32>;
				xlnx,debug-external-trace = <0>;
				xlnx,piaddr-size = <32>;
				xlnx,misaligned-exceptions = <1>;
				xlnx,use-bitman = <0>;
				xlnx,num-sync-ff-clk-debug = <2>;
				xlnx,debug-event-counters = <0>;
				xlnx,use-atomic = <0>;
				xlnx,i-axi = <1>;
				xlnx,icache-streams = <0>;
				xlnx,g-template-list = <0>;
				xlnx,dcache-line-len = <4>;
				xlnx,num-sync-ff-clk = <2>;
				xlnx,num-sync-ff-dbg-clk = <1>;
				xlnx,interconnect = <2>;
				xlnx,hartid = <0x00000000 0x00000000>;
				xlnx,debug-latency-counters = <0>;
				xlnx,edk-iptype = "PROCESSOR";
				xlnx,use-fpu = <0>;
				xlnx,icache-byte-size = <8192>;
				xlnx,edge-is-positive = <1>;
				xlnx,use-icache = <0>;
				d-cache-size = <8192>;
				xlnx,async-wakeup = <3>;
				xlnx,use-non-secure = <0>;
				xlnx,number-of-rd-addr-brk = <0>;
				d-cache-baseaddr = <0x00000000>;
				xlnx,use-compression = <0>;
				xlnx,avoid-primitives = <0>;
				xlnx,use-counters = <1>;
				xlnx,lockstep-slave = <0>;
				xlnx,use-ext-nm-brk = <0>;
				xlnx,pdaddr-size = <32>;
				xlnx,instr-size = <32>;
				xlnx,i-lmb = <1>;
				xlnx,lockstep-select = <0>;
				xlnx,lmb-data-size = <32>;
				xlnx,ic-axi-mon = <0>;
				xlnx,num-sync-ff-clk-irq = <1>;
				xlnx,fsl-links = <0>;
				timebase-frequency = <100000000>;
				xlnx,archid = <0x00000000 0x00000001>;
				xlnx,icache-force-tag-lutram = <0>;
				xlnx,dcache-data-width = <0>;
				xlnx,dcache-victims = <0>;
				xlnx,use-branch-target-cache = <0>;
				xlnx,debug-profile-size = <0>;
				xlnx,lockstep-master = <0>;
				xlnx,freq = <100000000>;
				xlnx,number-of-pc-brk = <1>;
				xlnx,imprecise-exceptions = <0>;
				xlnx,icache-data-width = <0>;
				xlnx,debug-counter-width = <64>;
			};
		};
		axi_gpio_0: axi_gpio@40000000 {
			xlnx,gpio-board-interface = "led_16bits";
			compatible = "xlnx,axi-gpio-2.0" , "xlnx,xps-gpio-1.00.a";
			xlnx,all-outputs = <1>;
			#gpio-cells = <2>;
			xlnx,gpio-width = <16>;
			clock-frequency = <100000000>;
			xlnx,rable = <0>;
			xlnx,dout-default = <0x00000000>;
			xlnx,is-dual = <1>;
			xlnx,ip-name = "axi_gpio";
			xlnx,tri-default-2 = <0xFFFFFFFF>;
			reg = <0x40000000 0x10000>;
			xlnx,all-inputs-2 = <1>;
			clocks = <&clk_bus_0>;
			xlnx,all-outputs-2 = <0>;
			gpio-controller;
			xlnx,interrupt-present = <0>;
			xlnx,gpio2-board-interface = "Custom";
			xlnx,edk-iptype = "PERIPHERAL";
			xlnx,dout-default-2 = <0x00000000>;
			xlnx,gpio2-width = <16>;
			status = "okay";
			clock-names = "s_axi_aclk";
			xlnx,use-board-flow;
			xlnx,tri-default = <0xFFFFFFFF>;
			xlnx,name = "axi_gpio_0";
			xlnx,all-inputs = <0>;
		};
		axi_gpio_1: axi_gpio@40010000 {
			xlnx,gpio-board-interface = "push_buttons_5bits";
			compatible = "xlnx,axi-gpio-2.0" , "xlnx,xps-gpio-1.00.a";
			xlnx,all-outputs = <0>;
			#gpio-cells = <2>;
			xlnx,gpio-width = <5>;
			clock-frequency = <100000000>;
			xlnx,rable = <0>;
			xlnx,dout-default = <0x00000000>;
			xlnx,is-dual = <0>;
			xlnx,ip-name = "axi_gpio";
			xlnx,tri-default-2 = <0xFFFFFFFF>;
			reg = <0x40010000 0x10000>;
			xlnx,all-inputs-2 = <0>;
			clocks = <&clk_bus_0>;
			xlnx,all-outputs-2 = <0>;
			gpio-controller;
			xlnx,interrupt-present = <0>;
			xlnx,gpio2-board-interface = "Custom";
			xlnx,edk-iptype = "PERIPHERAL";
			xlnx,dout-default-2 = <0x00000000>;
			xlnx,gpio2-width = <32>;
			status = "okay";
			clock-names = "s_axi_aclk";
			xlnx,use-board-flow;
			xlnx,tri-default = <0xFFFFFFFF>;
			xlnx,name = "axi_gpio_1";
			xlnx,all-inputs = <1>;
		};
		axi_gpio_2: axi_gpio@40020000 {
			xlnx,gpio-board-interface = "dip_switches_16bits";
			compatible = "xlnx,axi-gpio-2.0" , "xlnx,xps-gpio-1.00.a";
			xlnx,all-outputs = <0>;
			#gpio-cells = <2>;
			xlnx,gpio-width = <16>;
			clock-frequency = <100000000>;
			xlnx,rable = <0>;
			xlnx,dout-default = <0x00000000>;
			xlnx,is-dual = <0>;
			xlnx,ip-name = "axi_gpio";
			xlnx,tri-default-2 = <0xFFFFFFFF>;
			reg = <0x40020000 0x10000>;
			xlnx,all-inputs-2 = <0>;
			clocks = <&clk_bus_0>;
			xlnx,all-outputs-2 = <0>;
			gpio-controller;
			xlnx,interrupt-present = <0>;
			xlnx,gpio2-board-interface = "Custom";
			xlnx,edk-iptype = "PERIPHERAL";
			xlnx,dout-default-2 = <0x00000000>;
